<configuration>
  <conversionRule conversionWord="clr" converterClass="org.springframework.boot.logging.logback.ColorConverter"/>
  <conversionRule conversionWord="wex" converterClass="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <charset>UTF-8</charset> 
      <pattern>
        <!--Date-->%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} <!--Log level--> %clr(%5p) <!--Thread--> %clr(---){faint} %clr([%15.15t]){faint} <!--Logger-->%clr(%-30.30logger{29} %15(%replace([%X{tenant:-_NO_TENANT_}]){'\\[_NO_TENANT_\\]',''})){cyan} %clr(:){faint} %m%n%wex
      </pattern>
    </encoder>
  </appender>

  <!-- ACCESS CONTROL -->
  <logger name="com.k_int.folio">
    <level value="INFO" />
  </logger>

  <logger name="com.k_int.accesscontrol">
    <level value="INFO" />
  </logger>
  <!-- /ACCESS CONTROL -->


  <!--
  <logger name="org.springframework.security.web.authentication.AnonymousAuthenticationFilter">
    <level value="TRACE" />
  </logger>

  <logger name="grails.plugin.springsecurity.web.authentication.GrailsAnonymousAuthenticationFilter">
    <level value="TRACE" />
  </logger>

  <logger name="grails.plugin.springsecurity">
    <level value="DEBUG" />
  </logger>

  <logger name="org.springframework.security">
    <level value="DEBUG" />
  </logger>
  -->

  <logger name="org.hibernate.orm.deprecation">
    <level value="ERROR" />
  </logger>

  <logger name="com.k_int.okapi.OkapiSchemaHandler">
    <level value="INFO" />
  </logger>

  <logger name="org.olf.general.DocumentAttachment">
    <level value="DEBUG" />
  </logger>

  <logger name="com.k_int.web.toolkit.files">
    <level value="DEBUG" />
  </logger>

  <logger name="org.olf.dataimport.internal.titleInstanceResolvers">
    <level value="DEBUG" />
  </logger>

  <logger name="org.olf">
    <level value="INFO" />
  </logger>

  <logger name="org.springframework.jdbc.support" >
    <level value="ERROR" />
  </logger>

  <!-- Suppress HikariCP config logging to prevent JDBC URL and credentials appearing in logs (ERM-3619) -->
  <logger name="com.zaxxer.hikari.HikariConfig">
    <level value="WARN" />
  </logger>

  <logger name="com.zaxxer.hikari.pool.HikariPool">
    <level value="WARN" />
  </logger>

  <!-- ERM-3619: Suppress http-builder-ng HTTP client logger — at DEBUG it dumps full request/response including Authorization headers -->
  <logger name="groovyx.net.http">
    <level value="WARN" />
  </logger>

  <!-- ERM-3619: Suppress Micronaut HTTP client logger — at DEBUG it dumps request/response headers including x-okapi-token -->
  <logger name="io.micronaut.http.client">
    <level value="WARN" />
  </logger>


  <!--LOG SQL - VERBOSE!!!!!!-->
  <!--<logger name="org.hibernate.SQL">
    <level value="TRACE" />
    <appender-ref ref="STDOUT" />
  </logger>-->

  <!--This one for SQL bind parameters-->
  <!--<logger name="org.hibernate.type.descriptor.sql.BasicBinder">
    <level value="TRACE" />
    <appender-ref ref="STDOUT" />
  </logger>-->

  <appender name="JOB" class="org.olf.general.jobs.JobAwareAppender"/>

  <logger name="org.olf.PackageIngestService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.TitleIngestService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.dataimport.internal.titleInstanceResolvers">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.TitleEnricherService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.IdentifierService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.kb.adapters.GOKbOAIAdapter">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.CoverageService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.ImportService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.DocumentAttachmentService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.KbManagementService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.KbHarvestService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.UtilityService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.ErmResourceService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <!-- PushKBSpecific ones -->
  <logger name="org.olf.general.pushKB.PushKBService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.general.pushKB.PushKBClient">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <logger name="org.olf.PackageSyncService">
    <level value="DEBUG" />
    <appender-ref ref="JOB" />
  </logger>

  <!-- Default level should be info. -->
  <root level="warn">
    <appender-ref ref="STDOUT" />
  </root>
  
</configuration>
