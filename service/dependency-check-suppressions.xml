<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <suppress>
        <notes>JSON View plugins are versioned independently. They are not Grails Framework 3.2.3.</notes>
        <packageUrl regex="true">^pkg:maven/org\.grails(\.plugins)?/views-(json|core|json-templates)@.*$</packageUrl>
        <cpe>cpe:/a:grails:grails</cpe>
    </suppress>

    <suppress>
        <notes>Async/Events plugins are not Grails 5.0.2 Framework.</notes>
        <packageUrl regex="true">^pkg:maven/org\.grails(\.plugins)?/(async|events|grails-async|grails-events).*@.*$</packageUrl>
        <cpe>cpe:/a:grails:grails</cpe>
    </suppress>

    <suppress>
        <notes>The converters plugin version 5.0.0 is misidentified as the Grails 5.0.0 framework.</notes>
        <packageUrl regex="true">^pkg:maven/org\.grails\.plugins/converters@.*$</packageUrl>
        <cpe>cpe:/a:grails:grails:5.0.0</cpe>
    </suppress>

    <suppress>
        <notes>Grails Profiles use separate versioning. Project is actually Grails 6.2.3.</notes>
        <packageUrl regex="true">^pkg:maven/org\.grails\.profiles/(rest-api|base)@.*$</packageUrl>
        <cpe regex="true">cpe:/a:grails:grails:.*</cpe>
    </suppress>

    <suppress>
        <notes>Custom FOLIO plugin versioned 1.0.0, incorrectly flagged as Grails 1.0.0.</notes>
        <packageUrl regex="true">^pkg:maven/com\.k_int\.accesscontrol/access-control-grails@.*$</packageUrl>
        <cpe>cpe:/a:grails:grails:1.0.0</cpe>
    </suppress>

    <suppress>
        <notes>
            Grails 6 uses Spring 5.3.x. This RMI vulnerability is a known ghost hit for Spring 5.
            We suppress this specifically because we are not using HTTP Invoker.
        </notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework/spring-web@.*$</packageUrl>
        <vulnerabilityName>CVE-2016-1000027</vulnerabilityName>
    </suppress>

</suppressions>